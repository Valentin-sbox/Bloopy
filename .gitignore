# ============================================================================
# BLOCK GUARD v4.0.0 - GITIGNORE
# ============================================================================
# 
# Este archivo especifica qué archivos y carpetas Git debe ignorar.
# Estos archivos no se incluyen en el control de versiones.
# ============================================================================

# =============================================================================
# DEPENDENCIAS
# =============================================================================
node_modules/
.pnp
.pnp.js

# =============================================================================
# BUILD OUTPUTS
# =============================================================================
build/
dist/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.snap
*.zip
*.tar.gz

# =============================================================================
# ENVIRONMENT
# =============================================================================
.env.local
.env.development.local
.env.test.local
.env.production.local

# =============================================================================
# IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# LOGS
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# =============================================================================
# TESTING
# =============================================================================
coverage/

# =============================================================================
# ELECTRON
# =============================================================================
app/

# =============================================================================
# TEMPORARY FILES
# =============================================================================
*.tmp
*.temp
.cache/

# =============================================================================
# WORKSPACE DATA (USER DATA - NO INCLUIR EN GIT)
# =============================================================================
workspace/
*.db
*.sqlite

# =============================================================================
# BACKUP FILES
# =============================================================================
*.bak
*~
