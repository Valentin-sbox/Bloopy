{
  "name": "bloopy",
  "productName": "Bloopy",
  "version": "1.26.34",
  "description": "Bloopy - Editor de texto nativo para escritores. Organiza proyectos, escribe con formato enriquecido y realiza un seguimiento de tu progreso.",
  "main": "public/electron.js",
  "homepage": ".",
  "author": "Bloopy Team",
  "license": "MIT",
  "scripts": {
    "start": "react-app-rewired start",
    "build": "cross-env CI=false PUBLIC_URL=./ react-app-rewired build",
    "test": "react-app-rewired test",
    "test:unit": "react-app-rewired test --testPathPattern=tests/unit",
    "test:property": "react-app-rewired test --testPathPattern=tests/property",
    "test:integration": "react-app-rewired test --testPathPattern=tests/integration",
    "eject": "react-scripts eject",
    "electron": "electron .",
    "electron-dev": "concurrently \"cross-env BROWSER=none npm start\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "dev": "concurrently \"cross-env BROWSER=none npm start\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "quick": "concurrently \"cross-env BROWSER=none npm start\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "test-app": "npm run build && electron .",
    "build-app": "node build-app.js",
    "build-ultra": "node build-ultra.js",
    "build-fix-icon": "node build-fix-icon.js",
    "fix-wine-icon": "node fix-wine-icon.js",
    "fix-wine-build": "node fix-wine-build.js",
    "test-build": "node test-build.js",
    "build-release": "node scripts/build-release.js",
    "publish-release": "node publish-release.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@lexical/clipboard": "^0.40.0",
    "@lexical/code": "^0.40.0",
    "@lexical/history": "^0.40.0",
    "@lexical/html": "^0.40.0",
    "@lexical/link": "^0.40.0",
    "@lexical/list": "^0.40.0",
    "@lexical/markdown": "^0.40.0",
    "@lexical/plain-text": "^0.40.0",
    "@lexical/react": "^0.40.0",
    "@lexical/rich-text": "^0.40.0",
    "@lexical/selection": "^0.40.0",
    "@lexical/utils": "^0.40.0",
    "@mdi/js": "^7.4.47",
    "@mdi/light-font": "^0.2.63",
    "@mdi/react": "^1.6.1",
    "electron-updater": "^6.1.1",
    "fs-extra": "^11.1.1",
    "js-yaml": "^4.1.0",
    "lexical": "^0.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "tldraw": "^4.4.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "chokidar": "^3.5.3",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^25.0.0",
    "electron-builder": "^24.4.0",
    "ffmpeg-static": "^5.2.0",
    "react-app-rewired": "^2.2.1",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.Bloopy.app",
    "productName": "Bloopy",
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "package.json",
      "electron-updater.yml"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Valentin-sbox",
        "repo": "Bloopy"
      }
    ],
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "win": {
      "target": [
        "nsis"
      ],
      "certificateFile": null,
      "certificatePassword": null,
      "sign": false,
      "signDlls": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bloopy",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}