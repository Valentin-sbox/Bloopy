{
  "appId": "com.bloopy.app",
  "productName": "Bloopy",
  "copyright": "Copyright © 2026 Bloopy",
  "directories": {
    "output": "dist",
    "buildResources": "public/assets"
  },
  "files": [
    "build/**/*",
    "assets/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "build/electron.js"
  },
  "asarUnpack": [
    "build/src/main/**/*",
    "node_modules/uuid/**/*",
    "node_modules/js-yaml/**/*",
    "node_modules/argparse/**/*",
    "node_modules/esprima/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64",
          "ia32"
        ]
      }
    ],
    "icon": "/workspaces/Blockguard/public/assets/icon.ico",
    "certificateFile": null,
    "certificatePassword": null,
    "sign": false,
    "signDlls": false,
    "signingHashAlgorithms": null,
    "signtool": null,
    "publisherName": "Bloopy",
    "rcedit": false
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "allowToChangeDesktopIcon": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "createUninstallShortcut": true,
    "shortcutName": "Bloopy",
    "installerIcon": "public/assets/icon.ico",
    "uninstallerIcon": "public/assets/icon.ico",
    "installerHeaderIcon": "public/assets/icon.ico",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "deleteAppDataOnUninstall": false
  },
  "buildDependenciesFromSource": false,
  "publish": [
    {
      "provider": "github",
      "owner": "Valentin-sbox",
      "repo": "Bloopy",
      "releaseType": "release",
      "publishAutoUpdate": true
    }
  ],
  "generateUpdatesFilesForAllChannels": true,
  "sign": false,
  "signDlls": false,
  "certificateFile": null,
  "certificatePassword": null
}